<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit product</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="navbar-custom">
        <a href="/" class="brand">VGU E-com</a>
        <a href="/products" class="btn-plain btn-show">&larr; Back to products</a>
    </div>

    <div class="box">
        <h2>Edit product</h2>
        <form action="/products/<%= product._id %>?_method=PUT" method="POST">
            <label for="name">Product name</label>
            <input type="text" id="name" name="name" value="<%= product.name %>">

            <label for="image">Product image URL</label>
            <input type="text" id="image" name="image" value="<%= product.image %>">

            <label for="price">Product price</label>
            <input type="number" id="price" name="price" value="<%= product.price %>">

            <label for="desc">Product description</label>
            <input type="text" id="desc" name="desc" value="<%= product.desc %>">

            <button type="submit">Update</button>
        </form>
    </div>

</body>
</html>
